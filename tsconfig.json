{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "./engine",
    "outDir": "lib",
    "declaration": true,
    "sourceMap": true,
    "typeRoots": [
      "./node_modules/@types",
      "./@types"
    ],
    "isolatedModules": true
  },
  "exclude": [
    "web/vite-plugin-sdl-tsx.ts",
    "@types/package.d.ts"
  ],
  "include": [
    "engine",
    "@types"
  ]
}
