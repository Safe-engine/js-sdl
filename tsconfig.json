{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "#engine/physics": [
        "./engine/physics/Box2d.ts"
      ]
    },
    "rootDir": "./engine",
    "outDir": "lib",
    "declaration": true,
    "sourceMap": true,
    "typeRoots": [
      "./node_modules/@types",
      "./@types"
    ],
    "isolatedModules": true
  },
  "exclude": [
    "scripts/vite-plugin-sdl-tsx.ts",
    "src",
    "web"
  ],
  "include": [
    "src",
    "web",
    "engine",
    "@types"
  ]
}