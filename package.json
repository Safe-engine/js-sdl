{
  "name": "@safe-engine/sdl",
  "version": "1.0.1",
  "description": "safe-engine with sdl renderer support",
  "main": "lib/index.js",
  "types": "@types/package.d.ts",
  "files": [
    "lib",
    "@types"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "fix": "eslint ./engine --fix",
    "typecheck": "tsc --noEmit -p tsconfig.examples.json",
    "test:ts": "bun run typecheck && bun test tests",
    "test:native": "cmake -S . -B build && cmake --build build --target js_sdl3_native_tests --parallel && ctest --test-dir build --output-on-failure",
    "sync-res": "bun ./node_modules/safex-sync-res/src/index.ts",
    "predev": "bun run sync-res",
    "build": "tsc --build tsconfig.json",
    "dev": "vite build --watch --config native/vite.config.ts",
    "web:dev": "vite --config web/vite.config.ts --host",
    "web:build": "vite build --config web/vite.config.ts",
    "mobile:deps": "./scripts/bootstrap-mobile-deps.sh",
    "mobile:assets": "node ./scripts/generate-mobile-assets.mjs",
    "android:setup": "./scripts/setup-android.sh",
    "android:apk": "./scripts/package-android.sh apk release",
    "android:aab": "./scripts/package-android.sh aab release",
    "ios:project": "./scripts/generate-ios-project.sh",
    "ios:run": "./scripts/run-ios.sh",
    "ios:ipa": "./scripts/package-ios.sh"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.5.0",
    "typescript-eslint": "^8.62.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.3"
  },
  "dependencies": {
    "@esotericsoftware/spine-core": "4.2.118",
    "dragonbones-es": "^1.0.0",
    "planck": "^1.5.0",
    "safex-sync-res": "^1.4.2",
    "vite-plugin-safex-transform": "^1.0.4"
  }
}
